import React from 'react';

const MobileAdminMessages = ({ 
  entries, uniqueData, smsTemplate, setSmsTemplate, clearAll 
}) => {
  return (
    <div className="mobile-admin-container" style={{ padding: '0 1rem 120px 1rem', animation: 'fadeIn 0.5s ease-out' }}>
      
      {/* 문자 발송 섹션 */}
      <div className="premium-sms-card">
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '1rem' }}>
          <label style={{ fontSize: '0.85rem', color: 'var(--primary)', fontWeight: '800' }}>💬 이벤트 문자 템플릿</label>
          <button onClick={clearAll} className="clear-btn-minimal">내역 비우기</button>
        </div>
        
        <textarea 
          value={smsTemplate} 
          onChange={(e) => setSmsTemplate(e.target.value)} 
          placeholder="전송할 문자 내용을 입력하세요..."
          className="premium-textarea"
        />
        
        {/* 고광택 황금빛 문자 발송 버튼 */}
        <button 
          className="premium-gold-btn-wide"
          onClick={() => {
            const numbers = uniqueData.map(e => e.phone.replace(/[^0-9]/g, '')).join(',');
            window.location.href = `sms:${numbers}?body=${encodeURIComponent(smsTemplate)}`;
          }}
        >
          <span className="btn-label-bold">문자 발송 시작하기</span>
          <span className="btn-count-badge">({uniqueData.length}명)</span>
          <span className="btn-icon-gold-right">✉️</span>
        </button>
      </div>

      {/* 응모 내역 리스트 */}
      <div style={{ marginTop: '2rem' }}>
        <h4 style={{ color: '#666', fontSize: '0.75rem', marginBottom: '1rem', fontWeight: '800', textTransform: 'uppercase', letterSpacing: '1px' }}>📋 실시간 응모 리스트</h4>
        <div style={{ display: 'flex', flexDirection: 'column', gap: '8px' }}>
          {entries.length === 0 ? (
            <div className="empty-state">응모 내역이 없습니다.</div>
          ) : (
            entries.map((entry) => (
              <div key={entry.id} className="slim-entry-card">
                <div className="entry-row-main">
                  <span className="entry-name">{entry.name}</span>
                  <span className="entry-prize text-ellipsis">{entry.prize}</span>
                </div>
                <div className="entry-row-sub">
                  <span className="entry-phone">{entry.phone}</span>
                  <span className="entry-date">{entry.date}</span>
                </div>
              </div>
            ))
          )}
        </div>
      </div>

      <style dangerouslySetInnerHTML={{__html: `
        .premium-sms-card {
          background: rgba(15, 15, 15, 0.7);
          border: 1px solid rgba(197, 160, 89, 0.3);
          border-radius: 20px;
          padding: 1.2rem;
          box-shadow: 0 10px 40px rgba(0,0,0,0.5);
          backdrop-filter: blur(10px);
        }
        .premium-textarea {
          width: 100%;
          height: 100px;
          background: rgba(0,0,0,0.4);
          border: 1px solid #222;
          border-radius: 12px;
          padding: 1rem;
          color: #fff;
          font-size: 0.95rem;
          outline: none;
          margin-bottom: 1.2rem;
          resize: none;
          transition: border-color 0.3s ease;
        }
        .premium-textarea:focus { border-color: var(--primary); }

        .premium-gold-btn-wide {
          width: 100%;
          background: linear-gradient(135deg, #fceabb 0%, #fccd4d 40%, #f8b500 50%, #fccd4d 60%, #fbdf93 100%);
          color: #000;
          padding: 1.1rem;
          border-radius: 15px;
          border: 1px solid #ffeb3b;
          font-weight: 900;
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 10px;
          box-shadow: 0 0 25px rgba(255, 215, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.4);
          cursor: pointer;
          transition: all 0.2s ease;
        }
        .premium-gold-btn-wide:active { transform: scale(0.96); filter: brightness(1.1); }
        .btn-label-bold { font-size: 1rem; letter-spacing: -0.5px; }
        .btn-count-badge { font-size: 0.8rem; opacity: 0.7; }
        .btn-icon-gold-right { font-size: 1.1rem; }

        .clear-btn-minimal { background: none; border: 1px solid #331111; color: #ff4444; padding: 4px 10px; border-radius: 8px; font-size: 0.7rem; font-weight: 700; }

        .slim-entry-card {
          background: rgba(255,255,255,0.02);
          border: 1px solid rgba(255,255,255,0.05);
          border-radius: 12px;
          padding: 0.8rem 1rem;
          display: flex;
          flex-direction: column;
          gap: 4px;
        }
        .entry-row-main { display: flex; justify-content: space-between; align-items: center; }
        .entry-name { color: #fff; font-weight: 800; font-size: 0.95rem; }
        .entry-prize { color: var(--primary); font-weight: 700; font-size: 0.85rem; max-width: 50%; }
        .entry-row-sub { display: flex; justify-content: space-between; align-items: center; }
        .entry-phone { color: #666; font-size: 0.8rem; }
        .entry-date { color: #444; font-size: 0.7rem; }
        .empty-state { text-align: center; color: #333; padding: 3rem; font-size: 0.9rem; font-style: italic; }
        .text-ellipsis { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
      `}} />
    </div>
  );
};

export default MobileAdminMessages;
